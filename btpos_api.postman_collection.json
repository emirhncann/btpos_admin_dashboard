{
  "info": {
    "name": "BTPOS API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "https://api.btpos.com.tr"
    },
    {
      "key": "token",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Login - Başarılı",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "if (pm.response.code === 200) {",
              "  const json = pm.response.json();",
              "  pm.collectionVariables.set('token', json.token);",
              "  console.log('Token kaydedildi:', json.token);",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"admin@sirket.com\",\n  \"password\": \"123456\"\n}"
        },
        "url": "{{base_url}}/login"
      }
    },
    {
      "name": "Login - Yanlış Şifre",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"admin@sirket.com\",\n  \"password\": \"yanlis_sifre\"\n}"
        },
        "url": "{{base_url}}/login"
      }
    },
    {
      "name": "Login - Boş Alan",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"\",\n  \"password\": \"\"\n}"
        },
        "url": "{{base_url}}/login"
      }
    },
    {
      "name": "Kullanıcılar - Token ile",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "url": "{{base_url}}/users"
      }
    }
  ]
}
